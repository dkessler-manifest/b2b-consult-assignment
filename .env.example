# Supabase — get these from the Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co/rest/v1
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# B2B-specific: Supabase table name (defaults to b2b_attorney_profile if unset)
SUPABASE_TABLE_NAME=b2b_attorney_profile

# B2B Google Sheets availability (get Sheet ID and GID from the sheet URL)
# Leave blank to disable availability sync
GOOGLE_SHEETS_ID=<sheet-id>
GOOGLE_SHEETS_GID=<sheet-gid>

# Manifest API — for Cal.com private link generation
MANIFEST_API_URL=https://api-v2.manifestlaw.com
MANIFEST_API_KEY=<bearer-token>
